# ============================================================
# CanopySense Patcher-Local — Environment Configuration Template
#
# INSTRUCTIONS:
#   1. Copy this file to .env in your working directory
#   2. Replace every placeholder value with your actual values
#   3. NEVER commit .env to git (see GUIDANCE.md Section D)
#   4. Contact your administrator if you are missing any values
# ============================================================

# ── Cloud Function ────────────────────────────────────────────────────────────
# The full HTTPS URL of the CanopySense Cloud Function.
# Provided by your administrator at deployment time.
CLOUD_FUNCTION_URL=https://REGION-YOUR_PROJECT_ID.cloudfunctions.net/patcher_cloud

# Timeout in seconds for waiting on the Cloud Function response.
# Increase if you see timeout errors on large extraction runs.
# Default: 120 (2 minutes)
FUNCTION_TIMEOUT_SECONDS=120

# ── Contractor Identity ───────────────────────────────────────────────────────
# Your unique contractor identifier (assigned by administrator).
# Example: CONTRACTOR_ACME_FARMS
CONTRACTOR_ID=CONTRACTOR_YOUR_NAME

# Your unique API key (issued per contractor — never share this).
# Store this value ONLY here. Never hardcode it in any script.
PATCHER_API_KEY=your-api-key-here

# ── Local PostGIS Database Connection ────────────────────────────────────────
# Credentials for your LOCAL PostgreSQL/PostGIS instance.
# This is where Patcher-Local will write satellite_data records.
PGHOST=localhost
PGPORT=5432
PGDATABASE=canopysense
PGUSER=your_db_user
PGPASSWORD=your_db_password

# PostgreSQL schema name (default: canopysense).
# Controls which schema patcher_run_log and satellite_data are written to.
# PGSCHEMA=canopysense

# ── Patcher-Local v0.9 Optional Settings ─────────────────────────────────────
# How to group scheduled batches. Options: 'afdeling' (default) | 'none'
# Only change this if your blocks table has no afdeling_id data.
# BATCH_MODE=afdeling

# Expected api_version field in Cloud Function response (current: 1.1).
# Patcher-Local logs a warning if the deployed version differs — it does not break.
# Only update this if your administrator tells you to.
# PATCHER_API_VERSION=1.1
