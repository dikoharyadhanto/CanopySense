# CanopySense Backend — Environment Variables
# Copy to backend/.env (or project root .env) and fill in values.
# Never commit .env to version control.

# ─── Database ──────────────────────────────────────────────────────────────────
PGHOST=db
PGPORT=5432
PGUSER=postgres
PGPASSWORD=<strong-random-password>
PGDATABASE=canopysense

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Must be a strong random value of at least 32 characters.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<strong-random-64-char-hex>
ALGORITHM=HS256
# Access token lifetime in minutes. Default 60 min (Phase 1).
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Redis ─────────────────────────────────────────────────────────────────────
# With password: redis://:${REDIS_PASSWORD}@redis:6379/0
# Without password (local dev): redis://redis:6379/0
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=<strong-random-password>

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. No wildcard.
# Local dev example: http://localhost:3000
# Staging example:   https://staging.canopysense.app
ALLOWED_ORIGINS=http://localhost:3000

# ─── Cloud Function / GEE ──────────────────────────────────────────────────────
CLOUD_FUNCTION_URL=
PATCHER_API_KEY=
RASTER_CLOUD_TIMEOUT_SECONDS=60
CONTRACTOR_ID=
FUNCTION_TIMEOUT_SECONDS=120
PATCHER_API_VERSION=1.1

# ─── Email OTP (new device detection) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<smtp-user>
SMTP_PASSWORD=<smtp-app-password>
EMAIL_FROM=noreply@canopysense.app
# Device token lifetime in days before re-verification is required
DEVICE_TOKEN_EXPIRE_DAYS=90

# ─── Environment ───────────────────────────────────────────────────────────────
# Set to "production" to activate production guards (prevents staging_reset.py)
ENVIRONMENT=development

# ─── Staging Reset ─────────────────────────────────────────────────────────────
# Used by scripts/staging_reset.py only. Do not use in production.
RESET_ADMIN_USERNAME=canopy_superadmin
RESET_ADMIN_PASSWORD=<strong-random-password>

# ─── Testing ───────────────────────────────────────────────────────────────────
# Set TESTING=1 to skip startup SECRET_KEY strength validation in tests.
# TESTING=1
