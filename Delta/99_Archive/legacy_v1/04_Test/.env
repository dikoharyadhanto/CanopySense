# CanopySense — Local Development Environment
# PostGIS Docker (canopy-project-repos container)
PGHOST=localhost
PGPORT=5432
PGDATABASE=canopysense
PGUSER=postgres
PGPASSWORD=postgres

# GEE Credentials — set one of the following:
# Option A: Path to Service Account JSON key file
# EE_SERVICE_ACCOUNT_KEY=/path/to/your/service_account.json
#
# Option B: Service Account JSON as inline string
# EE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account",...}
#
# GEE Cloud Project ID
EE_PROJECT_ID=ee-dikoharyadhanto74

# Scheduler (disabled for Phase I local testing)
SCHEDULER_ENABLED=false

# ── Patcher-Local (Level 2 — Real GCF) ───────────────────────────────────────
CLOUD_FUNCTION_URL=https://asia-southeast2-canopysense.cloudfunctions.net/patcher_cloud
CONTRACTOR_ID=CONTRACTOR_TEST
PATCHER_API_KEY=my-test-key-123
FUNCTION_TIMEOUT_SECONDS=300
